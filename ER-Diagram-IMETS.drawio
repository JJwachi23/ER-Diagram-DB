  <diagram name="Page-1" id="bhhc_OJQYD5IOScPxzHB">
    <mxGraphModel dx="2754" dy="1909" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    %% Relationships defining how tables connect to each other\n    tbl_role ||--o{ tbl_user : \&quot;has\&quot;\n    tbl_role ||--o{ tbl_role_permission : \&quot;has\&quot;\n    tbl_permission ||--o{ tbl_role_permission : \&quot;assigned_to\&quot;\n    tbl_user ||--o| tbl_operator : \&quot;is_a\&quot;\n    tbl_machine ||--o{ tbl_machine_status_log : \&quot;logs_status\&quot;\n    tbl_machine ||--o{ tbl_alarm : \&quot;generates\&quot;\n    tbl_alarm ||--o{ tbl_alarm_history : \&quot;records_history\&quot;\n    tbl_machine ||--o{ tbl_production_record : \&quot;runs\&quot;\n    tbl_recipe ||--o{ tbl_production_record : \&quot;used_in\&quot;\n    tbl_operator ||--o{ tbl_production_record : \&quot;managed_by\&quot;\n    tbl_product ||--o{ tbl_production_record : \&quot;recorded_in\&quot;\n    tbl_product ||--o{ tbl_product_history : \&quot;has_events\&quot;\n    tbl_production_record ||--o{ tbl_inspection_result : \&quot;yields\&quot;\n    tbl_defect_type ||--o{ tbl_inspection_result : \&quot;identified_as\&quot;\n    tbl_machine ||--o{ tbl_kpi_summary : \&quot;measured_by\&quot;\n\n    %% Table Definitions\n    tbl_user {\n        int user_id PK\n        varchar username\n        varchar password_hash\n        varchar name\n        varchar email\n        int role_id FK\n        varchar status\n        datetime created_at\n    }\n\n    tbl_role {\n        int role_id PK\n        varchar role_name\n        varchar description\n    }\n\n    tbl_permission {\n        int permission_id PK\n        varchar permission_name\n        varchar description\n    }\n\n    tbl_role_permission {\n        int role_permission_id PK\n        int role_id FK\n        int permission_id FK\n    }\n\n    tbl_operator {\n        int operator_id PK\n        int user_id FK\n        varchar employee_no\n        varchar name\n        varchar department\n        varchar shift\n        varchar status\n    }\n\n    tbl_machine {\n        int machine_id PK\n        varchar machine_name\n        varchar machine_type\n        varchar location\n        varchar status\n        date install_date\n        varchar description\n    }\n\n    tbl_machine_status_log {\n        bigint status_log_id PK\n        int machine_id FK\n        varchar status\n        datetime start_time\n        datetime end_time\n        int duration\n        varchar remark\n    }\n\n    tbl_alarm {\n        bigint alarm_id PK\n        int machine_id FK\n        varchar alarm_type\n        varchar severity\n        datetime alarm_time\n        varchar status\n        int ack_by\n        datetime ack_time\n        varchar description\n    }\n\n    tbl_alarm_history {\n        bigint alarm_history_id PK\n        bigint alarm_id FK\n        varchar action\n        int action_by\n        datetime action_time\n        varchar remark\n    }\n\n    tbl_recipe {\n        int recipe_id PK\n        varchar product_model\n        varchar version\n        varchar feeder_setting\n        varchar vision_parameter\n        decimal cycle_time_target\n        varchar description\n        varchar is_active\n        int created_by\n        datetime create_time\n    }\n\n    tbl_production_record {\n        bigint record_id PK\n        int machine_id FK\n        int recipe_id FK\n        int operator_id FK\n        bigint product_id FK\n        datetime start_time\n        datetime end_time\n        decimal cycle_time\n        varchar result\n        varchar station_id\n        varchar remark\n    }\n\n    tbl_product {\n        bigint product_id PK\n        varchar serial_no\n        varchar lot_no\n        varchar model\n        datetime create_time\n        varchar final_status\n        varchar current_station\n    }\n\n    tbl_product_history {\n        bigint history_id PK\n        bigint product_id FK\n        varchar station_id\n        varchar event\n        datetime event_time\n        varchar remark\n    }\n\n    tbl_inspection_result {\n        bigint inspection_id PK\n        bigint record_id FK\n        varchar station_id\n        datetime inspect_time\n        varchar result\n        varchar defect_type_fk\n        decimal score\n        varchar image_path\n        varchar remark\n    }\n\n    tbl_defect_type {\n        int defect_type_id PK\n        varchar defect_type_name\n        varchar description\n    }\n\n    tbl_kpi_summary {\n        bigint kpi_id PK\n        int machine_id FK\n        date date\n        varchar shift\n        decimal uph\n        decimal availability\n        decimal performance\n        decimal quality\n        decimal oee\n        decimal reject_rate\n        datetime created_at\n    }\n\n    tbl_file_storage {\n        bigint file_id PK\n        varchar file_name\n        varchar file_type\n        varchar file_path\n        varchar related_type\n        bigint related_id\n        datetime upload_time\n        int uploaded_by\n        varchar description\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="FO-gx3G2YCvROCqrcctl-1">
